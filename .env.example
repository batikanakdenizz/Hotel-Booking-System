# ============================================================
# Hotel Booking System — Root .env Template
# ============================================================
# Copy this file to `.env` (gitignored) and fill in real values.
# Each service also has its own services/<svc>/.env.example with
# the subset it actually needs. The root .env aggregates everything
# so `docker compose up` can inject them all.
# ============================================================

# --- Logging ---
LOG_LEVEL=INFO

# ============================================================
# Firebase Authentication (Phase 1, §8.2)
# ============================================================
FIREBASE_PROJECT_ID=hotel-booking-system
# Paste the FULL JSON content of firebase-service-account.json as a single line:
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# ============================================================
# Supabase Postgres (Phase 1, §8.1)
# ============================================================
POSTGRES_URL=postgresql+asyncpg://postgres:<password>@db.xxxxxxxxxx.supabase.co:5432/postgres

# ============================================================
# Upstash Redis (Phase 1, §8.4) — used by search-service AND admin-service
# ============================================================
REDIS_URL=rediss://default:<password>@xxx-yyy-zzz.upstash.io:6379
HOTEL_DETAIL_TTL_SECONDS=86400      # 24h for hotel:{id}
DESTINATION_INDEX_TTL_SECONDS=21600 # 6h for destination:{name}:hotel_ids

# ============================================================
# MongoDB Atlas (Phase 1, §8.3) — comments-service only
# ============================================================
MONGO_URL=mongodb+srv://hotelapp:<password>@hotel-booking-cluster.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGO_DB_NAME=hotel_booking_comments

# ============================================================
# CloudAMQP RabbitMQ (Phase 1, §8.5)
# ============================================================
RABBITMQ_URL=amqps://username:password@xxx.rmq.cloudamqp.com/username
RABBITMQ_EXCHANGE=reservations-exchange
RABBITMQ_ROUTING_KEY=reservation.created
RABBITMQ_QUEUE=q.reservations.notifications
RABBITMQ_PUBLISH_MAX_RETRIES=3
RABBITMQ_PUBLISH_TIMEOUT_S=10

# ============================================================
# Groq LLM (Phase 1, §8.6) — ai-agent-service
# ============================================================
GROQ_API_KEY=gsk_xxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=                     # optional fallback

# ============================================================
# Resend Email (Phase 1, §8.7) — notification-service
# ============================================================
RESEND_API_KEY=re_xxxxxxxxxxxxxx
EMAIL_FROM=onboarding@resend.dev    # change if you verify your own domain

# ============================================================
# Cron Scheduler Secret (Phase 1, §8.10)
# Match this value to the X-Cron-Secret header in Google Cloud Scheduler
# ============================================================
CRON_SECRET=replace-with-random-uuid

# ============================================================
# Gateway routing (used by gateway service)
# In docker-compose these are container hostnames; in prod they are Render URLs.
# ============================================================
ADMIN_SERVICE_URL=http://admin-service:8001
SEARCH_SERVICE_URL=http://search-service:8002
BOOKING_SERVICE_URL=http://booking-service:8003
COMMENTS_SERVICE_URL=http://comments-service:8004
NOTIFICATION_SERVICE_URL=http://notification-service:8005
AGENT_SERVICE_URL=http://ai-agent-service:8006
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://hotel-booking.vercel.app
RATE_LIMIT_PER_MINUTE=60

# ============================================================
# AI agent → gateway loopback URL (for tool calls)
# ============================================================
GATEWAY_URL=http://gateway:8080
