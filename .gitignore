# ============================================================
# Hotel Booking System — .gitignore
# ============================================================

# --- Secrets & environment ---
.env
.env.local
.env.*.local
*.env
firebase-service-account.json
*-service-account.json
*.pem
*.key

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
*.egg
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/
.venv/
venv/
env/
ENV/

# --- Node / Frontend ---
node_modules/
.next/
.vite/
dist/
build/
*.local
.npm
.yarn-integrity
.pnp.*
.cache/

# --- Editors & OS ---
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# --- Logs ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Docker ---
docker-compose.override.yml

# --- Misc ---
*.bak
*.tmp
.claude/
recent.md

# --- Private learning / source materials (stay local, do not push) ---
docs/Guide/
docs/Lecture_Slides/
docs/developing_process.md
