# Frontend .env — copy to .env (gitignored) and fill in values from Phase 1.
# Vite only exposes vars prefixed with VITE_ to the browser.

# --- Firebase web SDK config (from Firebase console → Project settings → Web app) ---
VITE_FIREBASE_API_KEY=AIzaSyXXX
VITE_FIREBASE_AUTH_DOMAIN=hotel-booking-system.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=hotel-booking-system
VITE_FIREBASE_APP_ID=1:123:web:abc

# --- Gateway URL ---
# Dev: leave empty to use the Vite proxy (/api → http://localhost:8080)
# Prod: set to https://<your-gateway>.onrender.com
VITE_API_GATEWAY_URL=
