# Copy these into Vercel -> Project Settings -> Environment Variables.
# (Do NOT commit a real .env.production -- it is gitignored.)

# Public URL of the hbs-gateway service on Render.
VITE_API_GATEWAY_URL=https://hbs-gateway.onrender.com

# Firebase web SDK config (Project Settings -> General -> Your apps -> Web app)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
